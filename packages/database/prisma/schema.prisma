// FREX - Prisma schema (Phase 1 MVP + extensibility for Phase 2-4)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  shipper
  driver
  logistics_company
  storage_provider
}

enum VerificationStatus {
  pending
  partially_verified
  fully_verified
  flagged
  suspended
}

enum BookingStatus {
  draft
  booked
  driver_en_route
  pickup
  in_transit
  delivery
  completed
  cancelled
}

enum LoadClass {
  nano
  micro
  mega
  xl
}

enum VehicleType {
  bakkie
  van
  panel_van
  box_truck
  flatbed
  refrigerated
  moving_van
  crane
  tipper
  tanker
  medical_waste
  other
}

model User {
  id                 String             @id @default(cuid())
  email              String?            @unique
  phone              String?            @unique
  passwordHash       String?
  role               UserRole
  verificationStatus VerificationStatus @default(pending)
  trustScore         Float              @default(3.0)
  avatarUrl          String?
  deviceFingerprint  String?            // one account per device
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  sessions           Session[]
  shipperProfile      ShipperProfile?
  driverProfile       DriverProfile?
  logisticsProfile    LogisticsCompanyProfile?
  storageProfile      StorageProviderProfile?
  bookingsAsShipper   Booking[]         @relation("ShipperBookings")
  bookingsAsDriver   Booking[]         @relation("DriverBookings")
  ratingsGiven       Rating[]          @relation("Rater")
  ratingsReceived    Rating[]          @relation("Rated")
  payments           Payment[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShipperProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  businessName        String?
  businessType        String?
  vatNumber           String?
  defaultPaymentMethod String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverProfile {
  id             String       @id @default(cuid())
  userId         String       @unique
  fullName       String
  licenseNumber  String?
  licenseCode    String?
  rating         Float        @default(0)
  acceptanceRate Float        @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?
  vehicleId      String?      @unique
}

model Vehicle {
  id            String        @id @default(cuid())
  make          String
  model         String
  year          Int
  color         String?
  capacityKg    Float?
  lengthCm      Float?
  widthCm       Float?
  heightCm      Float?
  vehicleType   VehicleType
  registration  String?
  driverProfile DriverProfile?
}

model LogisticsCompanyProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  registrationNo  String?
  taxNumber       String?
  fleetSize       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StorageProviderProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  facilityName String
  address     String?
  capacitySqm Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id               String    @id @default(cuid())
  line1            String
  line2            String?
  city             String
  province         String?
  postalCode       String?
  country          String    @default("ZA")
  latitude         Float?
  longitude        Float?
  pickupBookings   Booking[] @relation("PickupAddress")
  dropoffBookings  Booking[] @relation("DropoffAddress")
}

model Booking {
  id                  String        @id @default(cuid())
  reference           String        @unique // human-readable e.g. FRX-XXXX
  shipperId           String
  driverId            String?
  status              BookingStatus @default(draft)
  loadClass           LoadClass
  vehicleType         VehicleType?
  totalAmountZar      Decimal       @db.Decimal(12, 2)
  platformFeeZar      Decimal       @db.Decimal(12, 2)
  driverEarningsZar   Decimal?      @db.Decimal(12, 2)
  declaredValueZar    Decimal       @db.Decimal(12, 2)
  distanceKm          Float?
  routeType           String?       // urban | intercity | rural
  scheduledAt         DateTime?
  pickupAt            DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  shipper             User          @relation("ShipperBookings", fields: [shipperId], references: [id])
  driver              User?         @relation("DriverBookings", fields: [driverId], references: [id])
  pickupAddress       Address?      @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  pickupAddressId     String?
  dropoffAddress      Address?      @relation("DropoffAddress", fields: [dropoffAddressId], references: [id])
  dropoffAddressId    String?
  items               BookingItem[]
  payments            Payment[]
  trackingEvents      TrackingEvent[]
  ratings             Rating[]
}

model BookingItem {
  id          String   @id @default(cuid())
  bookingId   String
  type        String
  weightKg    Float
  lengthCm    Float
  widthCm     Float
  heightCm    Float
  declaredValueZar Decimal @db.Decimal(12, 2)
  description String?
  photos      String[] // URLs
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String
  userId        String
  amountZar     Decimal  @db.Decimal(12, 2)
  currency      String   @default("ZAR")
  method        String   // card | eft | wallet | cash | mpesa
  status        String   // pending | held_escrow | completed | refunded | failed
  externalId    String?  // Stripe/PayFast etc
  paidAt        DateTime?
  payoutAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  booking       Booking  @relation(fields: [bookingId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

model TrackingEvent {
  id        String       @id @default(cuid())
  bookingId String
  status    BookingStatus
  latitude  Float?
  longitude Float?
  note      String?
  createdAt DateTime     @default(now())
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String
  raterId   String
  ratedId   String
  score     Int      // 1-5
  comment   String?
  criteria  Json?    // { onTime, care, communication, ... }
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rater     User     @relation("Rater", fields: [raterId], references: [id])
  rated     User     @relation("Rated", fields: [ratedId], references: [id])
}
